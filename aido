#!/usr/bin/env bash
# aido — wrapper for aido-proxy CLI
# Install: npm run install:global   (system-wide)
#      or: npm run install:local    (current user, no sudo)

# Resolve symlink so SCRIPT_DIR always points to the actual project folder
SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do
  SOURCE="$(readlink "$SOURCE")"
done
SCRIPT_DIR="$(cd "$(dirname "$SOURCE")" && pwd)"

exec node \
  --experimental-sqlite \
  --disable-warning=ExperimentalWarning \
  --import "$SCRIPT_DIR/node_modules/tsx/dist/esm/index.cjs" \
  "$SCRIPT_DIR/src/cli.ts" "$@"
