#!/usr/bin/env bash
# aido — wrapper for aido-proxy CLI
# Install: npm run install:global   (system-wide)
#      or: npm run install:local    (current user, no sudo)

# Resolve symlink so SCRIPT_DIR always points to the actual project folder
SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do
  SOURCE="$(readlink "$SOURCE")"
done
SCRIPT_DIR="$(cd "$(dirname "$SOURCE")" && pwd)"

# Use fnm Node 22 if available, fallback to system node
if [ -x "$HOME/.local/share/fnm/node-versions/v22.22.2/installation/bin/node" ]; then
  NODE_BIN="$HOME/.local/share/fnm/node-versions/v22.22.2/installation/bin/node"
elif command -v node &> /dev/null; then
  NODE_BIN="node"
else
  echo "Error: Node.js not found" >&2
  exit 1
fi

export DOTENV_CONFIG_PATH="$SCRIPT_DIR/.env"
export DB_PATH="$SCRIPT_DIR/aido.db"

exec "$NODE_BIN" \
  --dns-result-order=ipv4first \
  --experimental-sqlite \
  --disable-warning=ExperimentalWarning \
  --import "$SCRIPT_DIR/node_modules/tsx/dist/esm/index.cjs" \
  "$SCRIPT_DIR/src/cli.ts" "$@"
