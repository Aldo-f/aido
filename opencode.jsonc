{
  // AIDO - OpenCode Configuration
  // Run "aido proxy start" before using OpenCode
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "aido": {
      "name": "AIDO",
      "options": {
        "baseURL": "http://localhost:11999",
        "apiKey": "dummy" // Not required for local proxy
      }
    }
  },
  "model": "aido"
}
