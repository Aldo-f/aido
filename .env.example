# aido-proxy — API keys per provider
# Add keys with: aido add <key>
# Multiple keys are comma-separated (no spaces)

ZEN_KEYS=
OPENAI_KEYS=
ANTHROPIC_KEYS=
GROQ_KEYS=
GOOGLE_KEYS=
OLLAMA_KEYS=

# Local Ollama — no keys needed, just set the host if non-default
# OLLAMA_HOST=http://localhost:11434

# Proxy settings
PROXY_PORT=4141
DEFAULT_PROVIDER=zen
