# aido-proxy — API keys per provider
# Add keys with: aido add <key>
# Multiple keys are comma-separated (no spaces)

# Provider keys
ZEN_KEYS=
OPENAI_KEYS=
ANTHROPIC_KEYS=
GROQ_KEYS=
GOOGLE_KEYS=
OLLAMA_KEYS=

# Local Ollama — no keys needed, just set the host if non-default
# OLLAMA_HOST=http://localhost:11434

# Proxy settings
PROXY_PORT=4141
DEFAULT_PROVIDER=zen

# Hunt settings (for finding leaked keys)
# Get free key at: https://dashboard.exa.ai
EXA_API_KEY=

# GitHub token for scanning private repos (optional)
# Get token at: https://github.com/settings/tokens
# Required for gitleaks to clone private repos
GITHUB_TOKEN=
